# ---------------------------------------------------------------------------
# Copy this file to `.env` and adjust as needed:
#     cp .env.example .env        (macOS/Linux)
#     copy .env.example .env      (Windows)
#
# The suite runs out-of-the-box against the public OrangeHRM demo with these
# exact values, so `.env` is optional for a first run. `.env` is git-ignored;
# real credentials never get committed. All values are consumed through
# `src/config/env.ts` — no spec or page object reads process.env directly.
# ---------------------------------------------------------------------------

# Base URL of the OrangeHRM instance under test.
BASE_URL=https://opensource-demo.orangehrmlive.com

# Default administrator account shipped with the public demo.
ADMIN_USERNAME=Admin
ADMIN_PASSWORD=admin123

# Leave type used by the leave flow. The public demo's admin only has
# "CAN - Vacation" available; change it to match a different environment.
LEAVE_TYPE=CAN - Vacation
